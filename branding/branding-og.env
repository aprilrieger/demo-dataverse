# Sourced by scripts/apply-branding.sh
#
# Empty value = skip that setting (idempotent).
#
# Paths:
# - Web-served assets use /logos/... URLs
#   Host path:      branding/docroot/logos/...
#   Container path: /dv/docroot/logos/...
#
# - Dataverse customization files use *filesystem* paths in the API
#   Host path:      branding/docroot/branding/...
#   Container path: /dv/docroot/branding/...
#
# Examples:
#   LOGO_CUSTOMIZATION_FILE=/logos/navbar/logo.svg
#   HEADER_CUSTOMIZATION_FILE=/dv/docroot/branding/custom-header.html

###############################################################################
# Core installation branding
###############################################################################

# Public-facing installation name shown by Dataverse.
# Example:
# INSTALLATION_NAME='DataverseUp by Notch8'
# INSTALLATION_NAME='My Repository'
# INSTALLATION_NAME=''

# INSTALLATION_NAME=''

###############################################################################
# Navbar logo
###############################################################################

# Navbar logo URL must be a web path under /logos/...
# Example host file:
#   branding/docroot/logos/navbar/logo.svg
# Example value:
#   LOGO_CUSTOMIZATION_FILE=/logos/navbar/logo.svg
#
# Leave empty to skip.
# LOGO_CUSTOMIZATION_FILE=/logos/navbar/logo.svg

###############################################################################
# Root Dataverse theme header behavior
###############################################################################

# Hide the root Dataverse theme header (big banner).
#
# That block uses a different image URL pattern:
#   /logos/<dataverse-id>/<theme-logo-filename>
#
# If you are branding with LOGO_CUSTOMIZATION_FILE only, this is usually best set
# to true so you do not end up with two different logos or a broken theme image.
#
# Allowed values:
#   true
#   false
# DISABLE_ROOT_DATAVERSE_THEME=true

###############################################################################
# Customization files
###############################################################################

# These should point to in-container filesystem paths under /dv/docroot/branding/
# and correspond to files mounted from:
#   branding/docroot/branding/...
#
# Leave empty to skip.
#
# Typical files:
#   branding/docroot/branding/custom-header.html
#   branding/docroot/branding/custom-homepage.html
#   branding/docroot/branding/custom-footer.html
#   branding/docroot/branding/custom-stylesheet.css

# HEADER_CUSTOMIZATION_FILE=''
# HOME_PAGE_CUSTOMIZATION_FILE=''
# FOOTER_CUSTOMIZATION_FILE=''
# STYLE_CUSTOMIZATION_FILE=''

# Example values:
# HEADER_CUSTOMIZATION_FILE=/dv/docroot/branding/custom-header.html
# HOME_PAGE_CUSTOMIZATION_FILE=/dv/docroot/branding/custom-homepage.html
# FOOTER_CUSTOMIZATION_FILE=/dv/docroot/branding/custom-footer.html
# STYLE_CUSTOMIZATION_FILE=/dv/docroot/branding/custom-stylesheet.css

###############################################################################
# Footer text
###############################################################################

# FOOTER_COPYRIGHT is appended to the built-in:
#   Copyright © YEAR
#
# apply-branding.sh prepends a space unless your value already starts with:
#   space, tab, —, -, |, or (
#
# Multi-word values must be quoted.
#
# Examples:
# FOOTER_COPYRIGHT='Notch8'
# FOOTER_COPYRIGHT='| Powered by Notch8'
# FOOTER_COPYRIGHT='— Hosted by Notch8'
# FOOTER_COPYRIGHT='(Demo environment)'
# FOOTER_COPYRIGHT=''
# FOOTER_COPYRIGHT=''

###############################################################################
# Navbar links
###############################################################################

# Optional custom URLs for built-in navbar items.
# Leave empty to skip.
#
# Examples:
# NAVBAR_ABOUT_URL=https://notch8.com/about
# NAVBAR_SUPPORT_URL=mailto:support@notch8.com
# NAVBAR_GUIDES_URL=https://guides.dataverse.org/en/latest/

# NAVBAR_ABOUT_URL=''
# NAVBAR_SUPPORT_URL=''
# NAVBAR_GUIDES_URL=''

###############################################################################
# Demo / environment notes
###############################################################################

# Optional notes for humans maintaining this file.
# These are not consumed by apply-branding.sh unless you explicitly add support.
# Keep commented if purely informational.

# ENVIRONMENT_NAME='local'
# BRAND_NAME='DataverseUp'
# BRAND_TAGLINE='Hosted research data repositories, done right.'
# CONTACT_URL='https://notch8.com/contact'

###############################################################################
# Suggested starting point for a branded demo
###############################################################################

INSTALLATION_NAME='DataverseUp by Notch8'
LOGO_CUSTOMIZATION_FILE=/logos/navbar/logo.svg
DISABLE_ROOT_DATAVERSE_THEME=true
HEADER_CUSTOMIZATION_FILE=/dv/docroot/branding/custom-header.html
HOME_PAGE_CUSTOMIZATION_FILE=/dv/docroot/branding/custom-homepage.html
FOOTER_CUSTOMIZATION_FILE=/dv/docroot/branding/custom-footer.html
STYLE_CUSTOMIZATION_FILE=/dv/docroot/branding/custom-stylesheet.css
FOOTER_COPYRIGHT='<a href="https://notch8.com" rel="noopener noreferrer">Notch8</a>, your partner in digital preservation.'
NAVBAR_ABOUT_URL=https://notch8.com/about
NAVBAR_SUPPORT_URL=mailto:support@notch8.com
NAVBAR_GUIDES_URL=https://guides.dataverse.org/en/latest/