# =============================================================================
# Local installation branding (sourced by scripts/apply-branding.sh)
# Empty value = skip that API setting. Re-apply: docker compose run --rm dev_branding
# or ./bin/dev-up
#
# Web paths for the logo: /logos/...  -> files in branding/docroot/logos/...
# Custom HTML/CSS: use container paths /dv/docroot/branding/... (Compose mounts
# branding/docroot/branding there). See branding/docroot/branding/README.txt
# =============================================================================

# --- :InstallationName (emails, exports; can differ from root collection title)
INSTALLATION_NAME='Notch8 Dataverse live demo'

# --- :LogoCustomizationFile (navbar logo; web path, not filesystem)
LOGO_CUSTOMIZATION_FILE=/logos/navbar/logo.svg

# --- :DisableRootDataverseTheme (true = hide root collection theme banner / second logo)
DISABLE_ROOT_DATAVERSE_THEME=true

# --- Custom HTML/CSS (:HeaderCustomizationFile, etc.) — filesystem paths in API
HEADER_CUSTOMIZATION_FILE=/dv/docroot/branding/custom-header.html
FOOTER_CUSTOMIZATION_FILE=/dv/docroot/branding/custom-footer.html
STYLE_CUSTOMIZATION_FILE=/dv/docroot/branding/custom-stylesheet.css

# --- :HomePageCustomizationFile — REPLACES the root collection on /. Uncomment to preview.
HOME_PAGE_CUSTOMIZATION_FILE=/dv/docroot/branding/custom-homepage.html

# --- :FooterCopyright (appended after "Copyright © YEAR"; script adds a leading space)
FOOTER_COPYRIGHT='<a href="https://notch8.com" rel="noopener noreferrer">Notch8</a>, your partner in digital preservation.'

# --- Navbar links (optional; omit or leave empty to skip)
NAVBAR_ABOUT_URL=https://notch8.com/about
NAVBAR_SUPPORT_URL=mailto:support@notch8.com
NAVBAR_GUIDES_URL=https://guides.dataverse.org/en/latest/

# =============================================================================
# Not applied by apply-branding.sh (set in UI, compose env, or separate curl):
#   :WebAnalyticsCode, :GuidesBaseUrl, :GuidesVersion, root collection Theme,
#   dataverse.mail.system-email, terms URLs, :Languages, etc.
# Guide: https://guides.dataverse.org/en/latest/installation/config.html#branding-your-installation
# =============================================================================
