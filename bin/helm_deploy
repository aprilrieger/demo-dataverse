#!/bin/sh
#
# Helm upgrade/install for charts/demo-dataverse.
# Image and config come from the chart and HELM_EXTRA_ARGS (e.g. --values ops/<env>-deploy.yaml).

if [ -z "$1" ] || [ -z "$2" ]; then
  echo './bin/helm_deploy RELEASE_NAME NAMESPACE' >&2
  exit 1
fi

release_name="${1}"
namespace="${2}"

helm upgrade \
  --install \
  --atomic \
  --timeout 15m0s \
  $HELM_EXTRA_ARGS \
  --namespace="$namespace" \
  --create-namespace \
  "$release_name" \
  ./charts/demo-dataverse
